{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/eventcreator/layout,_N_T_/eventcreator/page,_N_T_/eventcreator"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
